{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/courses",
      "dest": "/api/courses.php"
    },
    {
      "src": "/logout",
      "dest": "/api/logout.php"
    }
  ]
}